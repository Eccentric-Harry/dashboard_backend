# Environment Variables - Strava Integration
# Copy this file as .env and fill in your actual values
# For local development, export these variables before running the backend

# Strava API Access Token
# Get this from: https://www.strava.com/settings/api
# On the "My API Application" page, copy your Access Token
STRAVA_ACCESS_TOKEN=your_strava_access_token_here

# Example with actual token format (DO NOT USE REAL TOKEN IN SOURCE CONTROL):
# STRAVA_ACCESS_TOKEN=e5f7c8e8d4c5b6a7f8e9d0c1b2a3f4e5a6b7c8d
